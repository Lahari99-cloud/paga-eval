# Generate with:
# python -c "from paga.storage import EncryptedProfileStore; print(EncryptedProfileStore.generate_key())"
PAGA_ENCRYPTION_KEY=replace-with-generated-fernet-key

# Generate independent secrets of at least 24 characters in your secrets manager.
PAGA_API_KEY=replace-with-long-api-key
PAGA_PROFILE_SALT=replace-with-long-profile-hmac-salt

# For tenant-scoped production keys, omit PAGA_API_KEY and provide compact JSON:
# PAGA_API_KEYS_JSON=[{"key":"replace-with-long-key","tenant_id":"district-a","permissions":["evaluate","report","profile:read","profile:write","operations"]}]

PAGA_DATABASE_PATH=/data/paga_profiles.sqlite3
PAGA_RETENTION_DAYS=30
PAGA_MAX_REQUEST_BYTES=32768
PAGA_LOG_REQUESTS=true
PAGA_MIN_ACOUSTIC_CONFIDENCE=0.72
PAGA_MIN_PHONEME_CONFIDENCE=0.5
PAGA_MAX_LOW_CONFIDENCE_PHONEME_RATIO=0.3

# During rotation, set old comma-separated keys here, deploy the new primary
# PAGA_ENCRYPTION_KEY, run EncryptedProfileStore.rotate_encryption(), then remove.
PAGA_DECRYPTION_KEYS=
