{
  "components": {
    "schemas": {
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "HostedEvaluationRequest": {
        "additionalProperties": false,
        "properties": {
          "acoustic_confidence_scores": {
            "anyOf": [
              {
                "items": {
                  "maximum": 1.0,
                  "minimum": 0.0,
                  "type": "number"
                },
                "maxItems": 256,
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Acoustic Confidence Scores"
          },
          "action": {
            "maxLength": 64,
            "minLength": 1,
            "title": "Action",
            "type": "string"
          },
          "attempt": {
            "maxLength": 256,
            "minLength": 1,
            "title": "Attempt",
            "type": "string"
          },
          "comparison_mode": {
            "default": false,
            "title": "Comparison Mode",
            "type": "boolean"
          },
          "evaluation_id": {
            "anyOf": [
              {
                "maxLength": 128,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Evaluation Id"
          },
          "target": {
            "maxLength": 256,
            "minLength": 1,
            "title": "Target",
            "type": "string"
          }
        },
        "required": [
          "target",
          "attempt",
          "action"
        ],
        "title": "HostedEvaluationRequest",
        "type": "object"
      },
      "PatternCategory": {
        "description": "Interpretation of a child's attempt. These are not clinical diagnoses.",
        "enum": [
          "clean_reading",
          "developmental_speech_pattern",
          "decoding_error",
          "uncertain_requires_review"
        ],
        "title": "PatternCategory",
        "type": "string"
      },
      "ProfileLookupRequest": {
        "additionalProperties": false,
        "properties": {
          "user_id": {
            "maxLength": 256,
            "minLength": 1,
            "title": "User Id",
            "type": "string"
          }
        },
        "required": [
          "user_id"
        ],
        "title": "ProfileLookupRequest",
        "type": "object"
      },
      "ProfileUpdateRequest": {
        "additionalProperties": false,
        "properties": {
          "category": {
            "$ref": "#/components/schemas/PatternCategory",
            "default": "developmental_speech_pattern"
          },
          "is_correct": {
            "default": false,
            "title": "Is Correct",
            "type": "boolean"
          },
          "pattern": {
            "maxLength": 128,
            "minLength": 1,
            "title": "Pattern",
            "type": "string"
          },
          "response_time": {
            "anyOf": [
              {
                "maximum": 3600.0,
                "minimum": 0.0,
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Response Time"
          },
          "user_id": {
            "maxLength": 256,
            "minLength": 1,
            "title": "User Id",
            "type": "string"
          }
        },
        "required": [
          "user_id",
          "pattern"
        ],
        "title": "ProfileUpdateRequest",
        "type": "object"
      },
      "ReportEvaluationRequest": {
        "additionalProperties": false,
        "properties": {
          "action": {
            "maxLength": 64,
            "minLength": 1,
            "title": "Action",
            "type": "string"
          },
          "attempt": {
            "maxLength": 256,
            "minLength": 1,
            "title": "Attempt",
            "type": "string"
          },
          "cohort": {
            "maxLength": 128,
            "minLength": 1,
            "title": "Cohort",
            "type": "string"
          },
          "evaluation_id": {
            "anyOf": [
              {
                "maxLength": 128,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Evaluation Id"
          },
          "target": {
            "maxLength": 256,
            "minLength": 1,
            "title": "Target",
            "type": "string"
          }
        },
        "required": [
          "target",
          "attempt",
          "action",
          "cohort"
        ],
        "title": "ReportEvaluationRequest",
        "type": "object"
      },
      "ReportRequest": {
        "additionalProperties": false,
        "properties": {
          "evaluations": {
            "items": {
              "$ref": "#/components/schemas/ReportEvaluationRequest"
            },
            "maxItems": 10000,
            "minItems": 1,
            "title": "Evaluations",
            "type": "array"
          }
        },
        "required": [
          "evaluations"
        ],
        "title": "ReportRequest",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
